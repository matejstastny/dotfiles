#!/usr/bin/env python3
"""Hold W key for Minecraft. Press Ctrl+C to stop."""

import time
import sys

try:
    from pynput.keyboard import Key, Controller
except ImportError:
    print("pynput not found. Install it with: pip install pynput")
    sys.exit(1)

keyboard = Controller()

print("Holding W in 3 seconds... Press Ctrl+C to stop.")
time.sleep(3)

keyboard.press('w')
print("Holding W. Press Ctrl+C to release and exit.")

try:
    while True:
        time.sleep(1)
except KeyboardInterrupt:
    keyboard.release('w')
    print("\nReleased W. Done.")
