#!/usr/bin/env bash

INPUT_DIR=$1
OUTPUT_DIR="${2:-avchd-export}"

if [ -z "$INPUT_DIR" ]; then
    echo "Usage: avchd INPUT_DIR [OUTPUT_DIR]"
    exit 1
fi

if ! command -v ffmpeg &>/dev/null; then
    echo "[!] ffmpeg not found in PATH."
    exit 2
fi

if [ ! -d "$INPUT_DIR" ]; then
    echo "[!] Input directory does not exist: $INPUT_DIR"
    exit 3
fi

mkdir -p "$OUTPUT_DIR"

LOG="$OUTPUT_DIR/avchd-export.log"

while IFS= read -r -d '' filepath; do
    name="$(basename "${filepath%.*}")"
    echo "[ ] Exporting: $filepath"
    ffmpeg -i "$filepath" -vcodec copy -acodec copy "$OUTPUT_DIR/$name.mp4" >>"$LOG" 2>&1
done < <(find "$INPUT_DIR" -name "*.MTS" -print0)

echo "[ ] Log: $LOG"
echo "[ ] Done."
