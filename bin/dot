#!/usr/bin/env python3

"""dot — dotfiles task manager"""

import argparse
import itertools
import os
import re
import shutil
import subprocess
import sys
import threading
import time
import tomllib
from pathlib import Path

DOTFILES_DIR = Path(__file__).resolve().parent.parent
ASSETS_DIR = DOTFILES_DIR / "assets"
FONT_DIR = ASSETS_DIR / "fonts"
CONFIGS_DIR = DOTFILES_DIR / "configs"
WALLPAPER_DIR = ASSETS_DIR / "wallpapers"
BREWFILE = DOTFILES_DIR / "Brewfile"
WALLPAPER = WALLPAPER_DIR / "wallpaper.png"
FONT_INSTALL_DIR = Path.home() / "Library" / "Fonts"
LINK_TOML = DOTFILES_DIR / "link.toml"
CLEAR_LINE = "\033[2K\r"

GREEN = "\033[32m"
YELLOW = "\033[33m"
RED = "\033[31m"
BLUE = "\033[34m"
CYAN = "\033[36m"
MAGENTA = "\033[35m"
DIM = "\033[2m"
RESET = "\033[0m"
BOLD = "\033[1m"


def rel(path: Path) -> str:
    return str(path).replace(str(Path.home()), "~")


def visible_len(s: str) -> int:
    return len(re.sub(r"\033\[[^m]*m", "", s))


def header(cmd: str, note: str = "") -> None:
    label = f"{BOLD}dot{RESET} {DIM}\u00b7{RESET} {BOLD}{cmd}{RESET}"
    suffix = f" {DIM}{note}{RESET}" if note else ""
    print(f"\n  {DIM}\u2500\u2500\u2500{RESET} {label}{suffix} {DIM}{'─' * 30}{RESET}\n")


def summary(*parts: str) -> None:
    print(f"\n  {' {0} '.format(f'{DIM}\u00b7{RESET}').join(parts)}\n")


def fatal(msg: str) -> None:
    print(f"  {RED}\u2717 {msg} (×_×){RESET}")
    sys.exit(1)



class Spinner:
    FRAMES = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]

    def __init__(self, msg: str = ""):
        self.msg = msg
        self._stop = threading.Event()
        self._thread: threading.Thread | None = None
        self._lock = threading.Lock()

    def __enter__(self):
        self._stop.clear()
        self._thread = threading.Thread(target=self._spin, daemon=True)
        self._thread.start()
        return self

    def _spin(self):
        for frame in itertools.cycle(self.FRAMES):
            if self._stop.is_set():
                break
            with self._lock:
                sys.stdout.write(f"{CLEAR_LINE}  {BLUE}{frame}{RESET} {self.msg}")
                sys.stdout.flush()
            time.sleep(0.08)

    def update(self, msg: str):
        self.msg = msg

    def log(self, msg: str):
        with self._lock:
            sys.stdout.write(f"{CLEAR_LINE}{msg}\n")
            sys.stdout.flush()

    def __exit__(self, *args):
        self._stop.set()
        if self._thread:
            self._thread.join()
        sys.stdout.write(CLEAR_LINE)
        sys.stdout.flush()


class ProgressBar:
    def __init__(self, total: int, label: str = "", width: int = 25):
        self.total = total
        self.current = 0
        self.label = label
        self.width = width

    def advance(self, n: int = 1):
        self.current += n
        self._draw()

    def _draw(self):
        pct = self.current / self.total if self.total else 1
        filled = int(self.width * pct)
        color = GREEN if self.current == self.total else BLUE
        bar = "\u2501" * filled + "\u2500" * (self.width - filled)
        sys.stdout.write(
            f"{CLEAR_LINE}  {self.label} {color}{bar}{RESET}"
            f" {DIM}{self.current}/{self.total}{RESET}"
        )
        sys.stdout.flush()

    def finish(self):
        self._draw()
        sys.stdout.write("\n")
        sys.stdout.flush()


def expand_path(value: str) -> str:
    return value.replace("$HOME", str(Path.home()))


def load_link_toml() -> tuple[dict[str, str], dict[str, str]]:
    """Load link.toml. Returns (directories, files) mappings."""
    directories: dict[str, str] = {}
    files: dict[str, str] = {}
    if not LINK_TOML.exists():
        return directories, files
    with open(LINK_TOML, "rb") as f:
        data = tomllib.load(f)
    for key, value in data.get("directories", {}).items():
        directories[key] = expand_path(value)
    for key, value in data.get("files", {}).items():
        files[key] = expand_path(value)
    return directories, files


TASK_ORDER = ["link", "brew", "assets"]
TASK_DESC = {
    "link": "Symlink configs to system locations",
    "brew": "Install/update Homebrew packages",
    "assets": "Install fonts and set wallpaper",
}



def link(force: bool = False, dry_run: bool = False) -> None:
    dir_exceptions, file_exceptions = load_link_toml()
    stats = {"new": 0, "ok": 0, "skipped": 0}

    header("link", "(dry run)" if dry_run else "")

    def confirm(msg: str) -> bool:
        if force:
            return True
        choice = input(f"  {YELLOW}? {msg} [y/N]{RESET} ").strip()
        return choice.lower() in ("y", "yes")

    def remove_target(target: Path) -> None:
        if dry_run:
            return
        if target.is_dir() and not target.is_symlink():
            shutil.rmtree(target)
        else:
            target.unlink(missing_ok=True)

    def link_symlink(src: Path, tgt: Path, label: str) -> None:
        if tgt.exists() or tgt.is_symlink():
            if tgt.is_symlink() and os.readlink(tgt) == str(src):
                print(f"  {DIM}\u2500  {label:<28} \u2192 {rel(tgt)}{RESET}")
                stats["ok"] += 1
                return
            if confirm(f"{tgt} exists. Overwrite?"):
                remove_target(tgt)
            else:
                print(f"  {YELLOW}\u25cb  {label:<28} \u2192 skipped{RESET}")
                stats["skipped"] += 1
                return
        if dry_run:
            print(f"  {CYAN}~  {label:<28} \u2192 {rel(tgt)}{RESET}")
        else:
            tgt.parent.mkdir(parents=True, exist_ok=True)
            tgt.symlink_to(src)
            print(f"  {GREEN}\u2713  {label:<28} \u2192 {rel(tgt)}{RESET}")
        stats["new"] += 1

    def link_files(src_dir: Path, tgt_dir: Path, folder_name: str) -> None:
        tgt_dir.mkdir(parents=True, exist_ok=True)
        for file in sorted(src_dir.iterdir()):
            link_symlink(file, tgt_dir / file.name, f"{folder_name}/{file.name}")

    for folder in sorted(CONFIGS_DIR.iterdir()):
        if not folder.is_dir():
            continue
        name = folder.name
        if name in file_exceptions:
            link_files(folder, Path(file_exceptions[name]), name)
        elif name in dir_exceptions:
            link_symlink(folder, Path(dir_exceptions[name]), name)
        else:
            link_symlink(folder, Path.home() / ".config" / name, name)

    parts = []
    if stats["new"]:
        parts.append(f"{GREEN}{stats['new']} linked{RESET}")
    if stats["ok"]:
        parts.append(f"{DIM}{stats['ok']} ok{RESET}")
    if stats["skipped"]:
        parts.append(f"{YELLOW}{stats['skipped']} skipped{RESET}")
    summary(*parts)



def brew_task() -> None:
    if shutil.which("brew") is None:
        fatal("Homebrew not installed!")
    if not BREWFILE.exists():
        fatal(f"Brewfile not found at {BREWFILE}!")

    header("brew")

    steps = [
        ("Updating Homebrew", ["brew", "update", "-q"]),
        ("Upgrading packages", ["brew", "upgrade", "-q"]),
        ("Installing from Brewfile", ["brew", "bundle", f"--file={BREWFILE}", "-q"]),
        ("Removing unlisted packages", ["brew", "bundle", "cleanup", f"--file={BREWFILE}", "--force", "-q"]),
        ("Cleaning up", ["brew", "cleanup"]),
    ]

    with Spinner() as sp:
        for i, (label, cmd) in enumerate(steps, 1):
            sp.update(f"{label}{DIM} ({i}/{len(steps)}){RESET}")
            result = subprocess.run(cmd, capture_output=True, text=True)
            if result.returncode != 0:
                sp.log(f"  {RED}\u2717  {label}{RESET}")
                fatal("Homebrew command failed!")
            sp.log(f"  {GREEN}\u2713{RESET}  {label}")

        # aider-chat needs Python 3.12+ (system Python uses LibreSSL which breaks urllib3 v2)
        if shutil.which("uv"):
            sp.update("Ensuring aider-chat uses Python 3.12\u2026")
            subprocess.run(
                ["uv", "tool", "install", "aider-chat", "--python", "3.12", "--force"],
                capture_output=True,
            )
            sp.log(f"  {GREEN}\u2713{RESET}  aider-chat (python 3.12)")

    summary(f"{GREEN}\u2713 Done (˶˃ ᵕ ˂˶){RESET}")


def assets() -> None:
    header("assets")

    FONT_INSTALL_DIR.mkdir(parents=True, exist_ok=True)
    installed = 0
    skipped = 0

    if FONT_DIR.is_dir():
        fonts = sorted(
            f for f in FONT_DIR.rglob("*") if f.suffix in (".ttf", ".otf")
        )
        if fonts:
            bar = ProgressBar(len(fonts), label="Fonts")
            for font in fonts:
                target = FONT_INSTALL_DIR / font.name
                if target.exists():
                    skipped += 1
                else:
                    try:
                        shutil.copy2(font, FONT_INSTALL_DIR)
                        installed += 1
                    except OSError:
                        pass
                bar.advance()
            bar.finish()

            parts = []
            if installed:
                parts.append(f"{GREEN}{installed} installed{RESET}")
            if skipped:
                parts.append(f"{DIM}{skipped} already present{RESET}")
            print(f"  {' {0} '.format(f'{DIM}\u00b7{RESET}').join(parts)}")
        else:
            print(f"  {YELLOW}\u26a0  No font files found{RESET}")
    else:
        print(f"  {YELLOW}\u26a0  No fonts directory{RESET}")

    print()
    if not WALLPAPER.exists():
        fatal(f"Wallpaper not found at {WALLPAPER}")

    with Spinner("Setting wallpaper\u2026"):
        result = subprocess.run(
            [
                "osascript", "-e",
                f'tell application "System Events" to set picture of every desktop to "{WALLPAPER}"',
            ],
            capture_output=True,
        )

    if result.returncode == 0:
        print(f"  {GREEN}\u2713{RESET}  Wallpaper set")
    else:
        print(f"  {YELLOW}\u26a0{RESET}  Failed to set wallpaper")

    summary(f"{GREEN}\u2713 Done (˶˃ ᵕ ˂˶){RESET}")



def check() -> None:
    dir_exceptions, file_exceptions = load_link_toml()

    header("check")

    rows: list[tuple[str, str, str]] = []

    for folder in sorted(CONFIGS_DIR.iterdir()):
        if not folder.is_dir():
            continue
        name = folder.name

        def add_row(label: str, src: Path, tgt: Path) -> None:
            r = rel(tgt)
            if not tgt.exists() and not tgt.is_symlink():
                rows.append((f"{RED}\u2717{RESET}", label, f"{RED}not linked{RESET}"))
            elif tgt.is_symlink():
                if os.readlink(tgt) == str(src):
                    rows.append((f"{GREEN}\u2713{RESET}", label, f"{DIM}{r}{RESET}"))
                else:
                    rows.append((f"{YELLOW}~{RESET}", label, f"{YELLOW}wrong target{RESET}"))
            else:
                rows.append((f"{YELLOW}!{RESET}", label, f"{YELLOW}not a symlink{RESET}"))

        if name in file_exceptions:
            for file in sorted(folder.iterdir()):
                add_row(f"{name}/{file.name}", file, Path(file_exceptions[name]) / file.name)
        elif name in dir_exceptions:
            add_row(name, folder, Path(dir_exceptions[name]))
        else:
            add_row(name, folder, Path.home() / ".config" / name)

    if not rows:
        print(f"  {DIM}No configs found.{RESET}")
        return

    name_w = max(visible_len(r[1]) for r in rows) + 2
    target_w = max(visible_len(r[2]) for r in rows) + 2
    inner_w = 3 + name_w + 3 + target_w

    print(f"  {DIM}\u256d{'─' * inner_w}\u256e{RESET}")
    for icon, name, target in rows:
        name_pad = " " * (name_w - visible_len(name))
        target_pad = " " * (target_w - visible_len(target))
        print(
            f"  {DIM}\u2502{RESET}"
            f" {icon}  {name}{name_pad}"
            f" {DIM}\u2192{RESET} {target}{target_pad}"
            f"{DIM}\u2502{RESET}"
        )
    print(f"  {DIM}\u2570{'─' * inner_w}\u256f{RESET}")

    linked = sum(1 for r in rows if "\u2713" in r[0])
    broken = len(rows) - linked
    parts = [f"{GREEN}{linked} linked{RESET}"]
    if broken:
        parts.append(f"{RED}{broken} broken{RESET}")
    summary(*parts)



def diff_task() -> None:
    if shutil.which("brew") is None:
        fatal("Homebrew not installed!")
    if not BREWFILE.exists():
        fatal(f"Brewfile not found at {BREWFILE}!")

    header("diff")

    with Spinner("Checking Brewfile\u2026"):
        check_result = subprocess.run(
            ["brew", "bundle", "check", f"--file={BREWFILE}", "--verbose"],
            capture_output=True, text=True,
        )
        cleanup_result = subprocess.run(
            ["brew", "bundle", "cleanup", f"--file={BREWFILE}", "--dry-run"],
            capture_output=True, text=True,
        )

    output = check_result.stdout + check_result.stderr
    missing = [line for line in output.splitlines() if line.startswith("\u2192")]
    extra = [
        line for line in cleanup_result.stdout.splitlines()
        if line.startswith("Would uninstall")
    ]

    print(f"  {BOLD}Missing{RESET} {DIM}(in Brewfile, not installed){RESET}")
    if not missing:
        print(f"  {DIM}  (none){RESET}")
    else:
        for line in missing:
            parts = line.split()
            pkg = parts[2] if len(parts) >= 3 else line
            print(f"  {RED}  \u2717  {pkg}{RESET}")

    print()
    print(f"  {BOLD}Extra{RESET} {DIM}(installed, not in Brewfile){RESET}")
    if not extra:
        print(f"  {DIM}  (none){RESET}")
    else:
        for line in extra:
            pkg = line.split()[-1]
            print(f"  {YELLOW}  ~  {pkg}{RESET}")

    print()



def run_task(name: str, **kwargs) -> None:
    match name:
        case "link":
            link(**kwargs)
        case "brew":
            brew_task()
        case "assets":
            assets()



def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="dot",
        description="dotfiles task manager",
    )
    sub = parser.add_subparsers(dest="command")

    link_p = sub.add_parser("link", help=TASK_DESC["link"])
    link_p.add_argument("--force", action="store_true", help="Overwrite without prompting")
    link_p.add_argument("--dry-run", action="store_true", help="Show what would happen")

    sub.add_parser("brew", help=TASK_DESC["brew"])
    sub.add_parser("assets", help=TASK_DESC["assets"])

    update_p = sub.add_parser("update", help="Sync: brew + link")
    update_p.add_argument("--force", action="store_true", help="Overwrite without prompting")
    update_p.add_argument("--dry-run", action="store_true", help="Show what would happen")

    sub.add_parser("all", help="Run all tasks")
    sub.add_parser("check", help="Show symlink status for all configs")
    sub.add_parser("diff", help="Show Brewfile vs installed packages")

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(1)

    link_kwargs = {}
    if args.command in ("link", "update"):
        link_kwargs = {"force": args.force, "dry_run": args.dry_run}

    match args.command:
        case "check":
            check()
        case "diff":
            diff_task()
        case "update":
            run_task("brew")
            run_task("link", **link_kwargs)
        case "all":
            for name in TASK_ORDER:
                run_task(name)
        case "link" | "brew" | "assets":
            run_task(args.command, **link_kwargs)


if __name__ == "__main__":
    main()
