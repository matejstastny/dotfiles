#!/usr/bin/env bash
set -euo pipefail

DOTFILES="$(cd "$(dirname "$0")/.." && pwd)"
CONFIGS="$DOTFILES/configs"
ASSETS="$DOTFILES/assets"
FONT_DIR="$ASSETS/fonts"
WALLPAPER="$ASSETS/wallpapers/wallpaper.png"
LINK_TOML="$DOTFILES/link.toml"

GREEN='\033[32m'; YELLOW='\033[33m'; RED='\033[31m'
CYAN='\033[36m'; DIM='\033[2m'; BOLD='\033[1m'; RESET='\033[0m'

OS=$(uname -s)
if [[ $OS == Darwin ]]; then
  FONTS_INSTALL="$HOME/Library/Fonts"
else
  FONTS_INSTALL="$HOME/.local/share/fonts"
fi

declare -A _DIRS _FILES

load_toml() {
  [[ -f $LINK_TOML ]] || return 0
  local sec=''
  while IFS= read -r line; do
    [[ $line =~ ^\[([^\]]+)\] ]] && { sec="${BASH_REMATCH[1]}"; continue; }
    [[ $line =~ ^([A-Za-z0-9_-]+)[[:space:]]*=[[:space:]]*\"([^\"]*)\" ]] || continue
    local key="${BASH_REMATCH[1]}" val="${BASH_REMATCH[2]/\$HOME/$HOME}"
    [[ $sec == directories ]] && _DIRS["$key"]="$val"
    [[ $sec == files       ]] && _FILES["$key"]="$val"
  done < "$LINK_TOML"
}

header() {
  printf "\n  ${BOLD}dot${RESET} ${DIM}Â·${RESET} ${BOLD}%s${RESET}%s\n\n" \
    "$1" "${2:+  ${DIM}($2)${RESET}}"
}

# Global counters (avoids set -e / dynamic-scoping interaction)
_FORCE=0; _DRY=0
_new=0; _ok=0; _skipped=0; _linked=0; _broken=0

do_symlink() {
  local label=$1 src=$2 tgt=$3
  if [[ -L $tgt && $(readlink "$tgt") == "$src" ]]; then
    printf "  ${DIM}â”€  %-30s â†’ %s${RESET}\n" "$label" "${tgt/$HOME/\~}"
    _ok=$(( _ok + 1 )); return
  fi
  if [[ -e $tgt || -L $tgt ]]; then
    if [[ $_FORCE -eq 1 ]]; then
      [[ $_DRY -eq 0 ]] && { [[ -d $tgt && ! -L $tgt ]] && rm -rf "$tgt" || rm -f "$tgt"; }
    else
      local ans
      read -rp "  ${YELLOW}?  ${tgt/$HOME/~} exists â€” overwrite? [y/N]${RESET} " ans
      if [[ ${ans,,} != y ]]; then
        printf "  ${YELLOW}â—‹  %-30s â†’ skipped${RESET}\n" "$label"
        _skipped=$(( _skipped + 1 )); return
      fi
      [[ $_DRY -eq 0 ]] && { [[ -d $tgt && ! -L $tgt ]] && rm -rf "$tgt" || rm -f "$tgt"; }
    fi
  fi
  if [[ $_DRY -eq 1 ]]; then
    printf "  ${CYAN}~  %-30s â†’ %s${RESET}\n" "$label" "${tgt/$HOME/\~}"
  else
    mkdir -p "$(dirname "$tgt")"
    ln -s "$src" "$tgt"
    printf "  ${GREEN}âś“  %-30s â†’ %s${RESET}\n" "$label" "${tgt/$HOME/\~}"
  fi
  _new=$(( _new + 1 ))
}

do_link_files() {
  local name=$1 src=$2 tgt_dir=$3
  [[ $_DRY -eq 0 ]] && mkdir -p "$tgt_dir"
  while IFS= read -r -d '' f; do
    do_symlink "$name/$(basename "$f")" "$f" "$tgt_dir/$(basename "$f")"
  done < <(find "$src" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
}

cmd_link() {
  _FORCE=0; _DRY=0; _new=0; _ok=0; _skipped=0
  while [[ $# -gt 0 ]]; do
    case "$1" in --force) _FORCE=1 ;; --dry-run) _DRY=1 ;; esac; shift
  done
  load_toml
  header link "${_DRY:+dry run}"

  for dir in "$CONFIGS"/*/; do
    [[ -d $dir ]] || continue
    local name src
    name=$(basename "$dir")
    src=$(realpath "$dir")
    if [[ -v _FILES[$name] ]]; then
      do_link_files "$name" "$src" "${_FILES[$name]}"
    elif [[ -v _DIRS[$name] ]]; then
      do_symlink "$name" "$src" "${_DIRS[$name]}"
    else
      do_symlink "$name" "$src" "$HOME/.config/$name"
    fi
  done

  local summary=""
  [[ $_new     -gt 0 ]] && summary+="${GREEN}${_new} linked${RESET}"
  [[ $_ok      -gt 0 ]] && summary+="${summary:+ Â· }${DIM}${_ok} ok${RESET}"
  [[ $_skipped -gt 0 ]] && summary+="${summary:+ Â· }${YELLOW}${_skipped} skipped${RESET}"
  printf "\n  %b\n\n" "${summary:-nothing to do}"
}

cmd_assets() {
  header assets

  mkdir -p "$FONTS_INSTALL"
  local installed=0 skipped=0
  while IFS= read -r -d '' font; do
    local tgt="$FONTS_INSTALL/$(basename "$font")"
    if [[ -f $tgt ]]; then
      skipped=$(( skipped + 1 ))
    else
      cp "$font" "$FONTS_INSTALL/"
      installed=$(( installed + 1 ))
    fi
  done < <(find "$FONT_DIR" \( -name '*.ttf' -o -name '*.otf' \) -print0 2>/dev/null)

  printf "  ${GREEN}âś“${RESET}  Fonts  ${GREEN}%d installed${RESET}  ${DIM}%d cached${RESET}\n" \
    "$installed" "$skipped"
  [[ $OS == Linux ]] && { fc-cache -f "$FONTS_INSTALL" 2>/dev/null || true; }

  if [[ ! -f $WALLPAPER ]]; then
    printf "  ${RED}âś—${RESET}  Wallpaper not found: %s\n" "$WALLPAPER"; return 1
  fi

  if [[ $OS == Darwin ]]; then
    osascript -e "tell application \"System Events\" to set picture of every desktop to \"$WALLPAPER\""
    printf "  ${GREEN}âś“${RESET}  Wallpaper set (macOS)\n"
  elif command -v swaybg &>/dev/null && [[ -n ${WAYLAND_DISPLAY:-} ]]; then
    pkill swaybg 2>/dev/null || true; sleep 0.1
    swaybg -i "$WALLPAPER" -m fill &
    printf "  ${GREEN}âś“${RESET}  Wallpaper set (swaybg)\n"
  elif command -v gsettings &>/dev/null; then
    gsettings set org.gnome.desktop.background picture-uri "file://$WALLPAPER"
    printf "  ${GREEN}âś“${RESET}  Wallpaper set (GNOME)\n"
  else
    printf "  ${YELLOW}âš ${RESET}  Wallpaper: no supported method found\n"
  fi

  printf "\n  ${GREEN}âś“ Done${RESET}\n\n"
}

check_row() {
  local label=$1 src=$2 tgt=$3 r="${3/$HOME/\~}"
  if [[ ! -e $tgt && ! -L $tgt ]]; then
    printf "  ${RED}âś—${RESET}  %-30s ${DIM}â†’${RESET}  ${RED}not linked${RESET}\n" "$label"
    _broken=$(( _broken + 1 ))
  elif [[ -L $tgt && $(readlink "$tgt") == "$src" ]]; then
    printf "  ${GREEN}âś“${RESET}  %-30s ${DIM}â†’${RESET}  ${DIM}%s${RESET}\n" "$label" "$r"
    _linked=$(( _linked + 1 ))
  elif [[ -L $tgt ]]; then
    printf "  ${YELLOW}~${RESET}  %-30s ${DIM}â†’${RESET}  ${YELLOW}wrong target${RESET}\n" "$label"
    _broken=$(( _broken + 1 ))
  else
    printf "  ${YELLOW}!${RESET}  %-30s ${DIM}â†’${RESET}  ${YELLOW}not a symlink${RESET}\n" "$label"
    _broken=$(( _broken + 1 ))
  fi
}

cmd_check() {
  _linked=0; _broken=0
  load_toml
  header check

  for dir in "$CONFIGS"/*/; do
    [[ -d $dir ]] || continue
    local name src
    name=$(basename "$dir")
    src=$(realpath "$dir")
    if [[ -v _FILES[$name] ]]; then
      while IFS= read -r -d '' f; do
        check_row "$name/$(basename "$f")" "$f" "${_FILES[$name]}/$(basename "$f")"
      done < <(find "$dir" -maxdepth 1 -mindepth 1 -print0 2>/dev/null)
    elif [[ -v _DIRS[$name] ]]; then
      check_row "$name" "$src" "${_DIRS[$name]}"
    else
      check_row "$name" "$src" "$HOME/.config/$name"
    fi
  done

  local summary="${GREEN}${_linked} linked${RESET}"
  [[ $_broken -gt 0 ]] && summary+=" Â· ${RED}${_broken} broken${RESET}"
  printf "\n  %b\n\n" "$summary"
}

case "${1:-}" in
  link)   shift; cmd_link "$@" ;;
  assets) cmd_assets ;;
  update) shift; cmd_link "$@"; cmd_assets ;;
  check)  cmd_check ;;
  *)
    printf "\n  ${BOLD}dot${RESET} â€” dotfiles manager\n\n"
    printf "  link    [--force] [--dry-run]   symlink configs\n"
    printf "  assets                          install fonts and set wallpaper\n"
    printf "  update  [--force] [--dry-run]   link + assets\n"
    printf "  check                           show symlink status\n\n"
    ;;
esac
