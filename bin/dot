#!/usr/bin/env bash

set -eu

# --------------------------------------------------------------------------------------------
# dot — dotfiles task manager
# --------------------------------------------------------------------------------------------
# Author: Matej Stastny
# License: MIT
# Link: https://github.com/matejstastny/dotfiles
# --------------------------------------------------------------------------------------------

# Constants ----------------------------------------------------------------------------------

DOTFILES_DIR="$(cd "$(dirname "$0")/.." && pwd)"
ASSETS_DIR="$DOTFILES_DIR/assets"
FONT_DIR="$ASSETS_DIR/fonts"
CONFIGS_DIR="$DOTFILES_DIR/configs"
WALLPAPER_DIR="$ASSETS_DIR/wallpapers"
BREWFILE="$DOTFILES_DIR/Brewfile"
WALLPAPER="${WALLPAPER_DIR}/wallpaper.png"
FONT_INSTALL_DIR="$HOME/Library/Fonts"

# Colors (Kanagawa)
KG_GREEN='\033[38;2;152;187;108m'  # #98BB6C
KG_YELLOW='\033[38;2;230;195;132m' # #E6C384
KG_RED='\033[38;2;195;64;67m'      # #C34043
KG_ORANGE='\033[38;2;255;160;102m' # #FFA066
KG_BLUE='\033[38;2;126;156;216m'   # #7E9CD8
KG_CYAN='\033[38;2;127;180;202m'   # #7FB4CA
KG_PURPLE='\033[38;2;149;127;184m' # #957FB8
KG_DIM='\033[38;2;114;113;105m'    # #727169
RESET='\033[0m'
BOLD='\033[1m'

# Logging ------------------------------------------------------------------------------------

log() {
	local level="$1"
	local msg="$2"
	local emoji color
	case "$level" in
	info)
		emoji=""
		color="$KG_BLUE"
		;;
	success)
		emoji=""
		color="$KG_GREEN"
		;;
	success-done)
		emoji="󰄭"
		color="$KG_PURPLE"
		;;
	celebrate)
		emoji="󰄛"
		color="$KG_BLUE"
		;;
	prompt)
		emoji=""
		color="$KG_CYAN"
		;;
	warn)
		emoji=""
		color="$KG_YELLOW"
		;;
	error)
		emoji=""
		color="$KG_RED"
		;;
	*)
		emoji=" 󱗜"
		color=""
		;;
	esac
	echo -e "${color}${emoji} ${msg}${RESET}"
}

log_fatal() {
	log error "$1"
	exit 1
}

# Task registry ------------------------------------------------------------------------------

TASK_ORDER=(link brew assets)

declare -A TASK_DESC=(
	[link]="Symlink configs to system locations"
	[brew]="Install/update Homebrew packages"
	[assets]="Install fonts and set wallpaper"
)

# link() -------------------------------------------------------------------------------------

link() {
	declare -A FILE_EXCEPTIONS=(
		[zsh]="$HOME"
		[git]="$HOME"
		[claude]="$HOME/.claude"
		[vscode]="$HOME/Library/Application Support/Code/User"
		[vesktop]="$HOME/Library/Application Support/vesktop/themes"
	)

	FORCE=false
	DRY_RUN=false
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--force) FORCE=true ;;
		--dry-run) DRY_RUN=true ;;
		*)
			echo "Unknown option: $1"
			exit 1
			;;
		esac
		shift
	done

	prompt_or_force() {
		local prompt_msg="$1"
		if [ "$FORCE" = true ]; then return 0; fi
		read -rp "$(log prompt "$prompt_msg") [y/N] " choice
		[[ "$choice" =~ ^[Yy]$ ]]
	}

	remove_target() {
		local target="$1"
		if $DRY_RUN; then
			log warn "Would remove existing $target"
		else
			rm -rf "$target"
		fi
	}

	link_symlink() {
		local src="$1"
		local tgt="$2"
		if [ -e "$tgt" ] || [ -L "$tgt" ]; then
			if [ -L "$tgt" ] && [ "$(readlink "$tgt")" = "$src" ]; then
				log success-done "$(basename "$tgt") already points to correct source"
				return
			fi
			if prompt_or_force "Target $tgt exists. Overwrite?"; then
				remove_target "$tgt"
			else
				log info "Skipped linking $tgt"
				return
			fi
		fi
		if $DRY_RUN; then
			log success "Would link $tgt -> $src"
		else
			ln -s "$src" "$tgt" && log success "Linked $tgt -> $src"
		fi
	}

	link_files() {
		local src_dir="$1"
		local tgt_dir="$2"
		mkdir -p "$tgt_dir"
		shopt -s dotglob nullglob
		for file in "$src_dir"/*; do
			[ -e "$file" ] || continue
			local filename
			filename="$(basename "$file")"
			link_symlink "$file" "$tgt_dir/$filename"
		done
		shopt -u dotglob nullglob
	}

	link_config() {
		local folder_name="$1"
		local src="$CONFIGS_DIR/$folder_name"
		if [[ -v FILE_EXCEPTIONS[$folder_name] ]]; then
			link_files "$src" "${FILE_EXCEPTIONS[$folder_name]}"
		else
			local tgt="$HOME/.config/$folder_name"
			link_symlink "$src" "$tgt"
		fi
	}

	for folder in "$CONFIGS_DIR"/*; do
		[ -d "$folder" ] || continue
		folder_name="$(basename "$folder")"
		link_config "$folder_name"
	done

	log celebrate "All done!"
}

# brew() -------------------------------------------------------------------------------------

brew_task() {
	if ! command -v brew >/dev/null 2>&1; then
		log_fatal "Homebrew not installed!"
	fi

	brew_failed() { log_fatal "Homebrew command failed!"; }

	if [[ ! -f "$BREWFILE" ]]; then
		log_fatal "Brewfile not found at $BREWFILE!"
	fi

	log info "Updating Homebrew..."
	brew update -q || brew_failed

	log info "Upgrading packages..."
	brew upgrade -q || brew_failed

	log info "Installing packages from Brewfile..."
	brew bundle --file="$BREWFILE" -q || brew_failed

	log info "Uninstalling packages not in Brewfile..."
	brew bundle cleanup --file="$BREWFILE" --force -q || brew_failed

	log info "Cleaning up..."
	brew cleanup || brew_failed

	log celebrate "All done!"
}

# assets() -----------------------------------------------------------------------------------

assets() {
	# Fonts
	log info "Installing fonts..."
	log info "Font source: $FONT_DIR"
	log info "Target: $FONT_INSTALL_DIR"
	mkdir -p "$FONT_INSTALL_DIR"

	if [ -d "$FONT_DIR" ]; then
		mapfile -d '' fonts < <(find "$FONT_DIR" \( -name "*.ttf" -o -name "*.otf" \) -print0)
		font_count=${#fonts[@]}
		if ((font_count > 0)); then
			log info "Found $font_count font(s) to install."
			for font in "${fonts[@]}"; do
				target_font="$FONT_INSTALL_DIR/$(basename "$font")"
				if [[ -f "$target_font" ]]; then
					log success-done "Font already exists: $(basename "$font")"
				else
					if cp "$font" "$FONT_INSTALL_DIR/"; then
						log success "Installed font: $(basename "$font")"
					else
						log warn "Failed to install font: $(basename "$font")"
					fi
				fi
			done
		else
			log warn "No font files found in $FONT_DIR."
		fi
	else
		log warn "No fonts directory found at $FONT_DIR."
	fi

	# Wallpaper
	if [ ! -f "$WALLPAPER" ]; then
		log_fatal "Wallpaper not found at $WALLPAPER"
	fi
	log info "Setting wallpaper: $WALLPAPER"
	if osascript -e "tell application \"System Events\" to set picture of every desktop to \"${WALLPAPER}\""; then
		log success "Wallpaper set."
	else
		log warn "Failed to set wallpaper via AppleScript."
	fi

	# bat Kanagawa theme
	log info "Installing bat Kanagawa theme..."
	mkdir -p "$(bat --config-dir)/themes"
	src_theme="$CONFIGS_DIR/bat/themes/kanagawa.tmTheme"
	dst_theme="$(bat --config-dir)/themes/kanagawa.tmTheme"
	if [ "$src_theme" != "$dst_theme" ] && [ ! -e "$dst_theme" ]; then
		cp "$src_theme" "$dst_theme"
	fi
	bat cache --build >/dev/null

	log celebrate "All done!"
}

# check() ------------------------------------------------------------------------------------

check() {
	declare -A FILE_EXCEPTIONS=(
		[zsh]="$HOME"
		[git]="$HOME"
		[claude]="$HOME/.claude"
		[vscode]="$HOME/Library/Application Support/Code/User"
		[vesktop]="$HOME/Library/Application Support/vesktop/themes"
	)

	echo
	echo -e "  ${BOLD}dot check${RESET} — symlink status"
	echo -e "  ${KG_DIM}──────────────────────────────────────${RESET}"

	for folder in "$CONFIGS_DIR"/*; do
		[ -d "$folder" ] || continue
		name="$(basename "$folder")"

		if [[ -v FILE_EXCEPTIONS[$name] ]]; then
			# Check each file in the directory
			shopt -s dotglob nullglob
			for file in "$folder"/*; do
				[ -e "$file" ] || continue
				filename="$(basename "$file")"
				tgt="${FILE_EXCEPTIONS[$name]}/$filename"
				rel_tgt="${tgt/$HOME/\~}"
				label="$name/$filename"

				if [ ! -e "$tgt" ] && [ ! -L "$tgt" ]; then
					printf "  ${KG_RED}✗${RESET}  %-28s → not linked\n" "$label"
				elif [ -L "$tgt" ]; then
					actual="$(readlink "$tgt")"
					if [ "$actual" = "$file" ]; then
						printf "  ${KG_GREEN}✓${RESET}  %-28s → %s\n" "$label" "$rel_tgt"
					else
						printf "  ${KG_YELLOW}~${RESET}  %-28s → wrong target\n" "$label"
					fi
				else
					printf "  ${KG_ORANGE}!${RESET}  %-28s → exists but not a symlink\n" "$label"
				fi
			done
			shopt -u dotglob nullglob
		else
			tgt="$HOME/.config/$name"
			rel_tgt="~/.config/$name"

			if [ ! -e "$tgt" ] && [ ! -L "$tgt" ]; then
				printf "  ${KG_RED}✗${RESET}  %-28s → not linked\n" "$name"
			elif [ -L "$tgt" ]; then
				actual="$(readlink "$tgt")"
				if [ "$actual" = "$folder" ]; then
					printf "  ${KG_GREEN}✓${RESET}  %-28s → %s\n" "$name" "$rel_tgt"
				else
					printf "  ${KG_YELLOW}~${RESET}  %-28s → wrong target\n" "$name"
				fi
			else
				printf "  ${KG_ORANGE}!${RESET}  %-28s → exists but not a symlink\n" "$name"
			fi
		fi
	done
	echo
}

# diff() -------------------------------------------------------------------------------------

diff_task() {
	if ! command -v brew >/dev/null 2>&1; then
		log_fatal "Homebrew not installed!"
	fi
	if [[ ! -f "$BREWFILE" ]]; then
		log_fatal "Brewfile not found at $BREWFILE!"
	fi

	echo
	echo -e "  ${BOLD}dot diff${RESET} — Brewfile vs installed"
	echo -e "  ${KG_DIM}──────────────────────────────────────${RESET}"

	echo -e "\n  Missing (in Brewfile, not installed):"
	missing=$(brew bundle check --file="$BREWFILE" --verbose 2>&1 | grep -v "^✓" || true)
	if [[ -z "$missing" ]]; then
		echo -e "  ${KG_GREEN}  (none)${RESET}"
	else
		while IFS= read -r line; do
			pkg=$(echo "$line" | sed 's/^[^[:alnum:]]*//' | awk '{print $NF}')
			printf "  ${KG_RED}  ✗  %s${RESET}\n" "$pkg"
		done <<<"$missing"
	fi

	echo -e "\n  Extra (installed, not in Brewfile):"
	extra=$(brew bundle cleanup --file="$BREWFILE" --dry-run 2>/dev/null | grep "^Would uninstall" || true)
	if [[ -z "$extra" ]]; then
		echo -e "  ${KG_GREEN}  (none)${RESET}"
	else
		while IFS= read -r line; do
			pkg=$(echo "$line" | awk '{print $NF}')
			printf "  ${KG_YELLOW}  ~  %s${RESET}\n" "$pkg"
		done <<<"$extra"
	fi
	echo
}

# usage() ------------------------------------------------------------------------------------

usage() {
	echo
	echo -e "  ${BOLD}dot${RESET} — dotfiles task manager"
	echo
	echo -e "  Usage: ${KG_CYAN}dot <command>${RESET}"
	echo
	echo -e "  ${KG_DIM}Tasks:${RESET}"
	echo -e "    ${KG_BLUE}link${RESET}      ${TASK_DESC[link]}"
	echo -e "    ${KG_BLUE}brew${RESET}      ${TASK_DESC[brew]}"
	echo -e "    ${KG_BLUE}assets${RESET}    ${TASK_DESC[assets]}"
	echo -e "    ${KG_BLUE}update${RESET}    Sync: brew + link"
	echo -e "    ${KG_BLUE}all${RESET}       Run all tasks"
	echo
	echo -e "  ${KG_DIM}Info:${RESET}"
	echo -e "    ${KG_PURPLE}check${RESET}     Show symlink status for all configs"
	echo -e "    ${KG_PURPLE}diff${RESET}      Show Brewfile vs installed packages"
	echo
	exit 1
}

# run_task() ---------------------------------------------------------------------------------

run_task() {
	local name="$1"
	shift
	echo
	echo -e "${BOLD}Running ${KG_BLUE}${name}${RESET}${BOLD}...${RESET}"
	echo -e "${KG_DIM}──────────────────────────────────────${RESET}"
	case "$name" in
	link) link "$@" ;;
	brew) brew_task ;;
	assets) assets ;;
	esac
}

# Argument parsing ---------------------------------------------------------------------------

if [ $# -eq 0 ]; then
	usage
fi

arg="$1"
shift

case "$arg" in
check)
	check
	;;
diff)
	diff_task
	;;
update)
	run_task brew
	run_task link "$@"
	;;
all)
	for name in "${TASK_ORDER[@]}"; do
		run_task "$name"
	done
	;;
link | brew | assets)
	run_task "$arg" "$@"
	;;
*)
	echo "dot: Unknown command '$arg'"
	usage
	;;
esac
