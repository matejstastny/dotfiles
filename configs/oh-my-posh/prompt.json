{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#E29BD8",
          "style": "plain",
          "template": " \n\u279c",
          "type": "text"
        },
        {
          "foreground": "#BB9AF7",
          "options": {
            "style": "folder"
          },
          "style": "plain",
          "template": " {{ .Path }}",
          "type": "path"
        },
        {
          "foreground": "#C678DD",
          "options": {
            "branch_icon": ""
          },
          "style": "plain",
          "template": " <#E29BD8>git(</>{{ .HEAD }}<#E29BD8>)</>",
          "type": "git"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}
