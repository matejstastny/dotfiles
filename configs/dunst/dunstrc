[global]
    monitor    = 0
    follow     = mouse

    width      = (0, 360)
    height     = (0, 200)
    origin     = top-right
    offset     = (14, 14)
    scale      = 0

    notification_limit = 5
    progress_bar = true
    progress_bar_height = 4
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 2

    padding             = 14
    horizontal_padding  = 16
    text_icon_padding   = 12
    frame_width         = 1
    gap_size            = 6

    corner_radius = 8

    transparency = 0

    idle_threshold = 120

    font = JetBrainsMono Nerd Font Mono 12

    line_height   = 4
    markup        = full
    format        = "<b>%s</b>\n%b"
    alignment     = left
    vertical_alignment = center
    word_wrap     = yes
    ellipsize     = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position     = left
    min_icon_size     = 28
    max_icon_size     = 40
    icon_corner_radius = 4

    sticky_history    = yes
    history_length    = 20

    browser = firefox --new-tab

    mouse_left_click   = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click  = close_all

    always_run_script  = true
    title              = Dunst
    class              = Dunst

[urgency_low]
    background    = "#1a1a28"
    foreground    = "#888899"
    frame_color   = "#2a2a3e"
    highlight     = "#bb9af7"
    timeout       = 4
    default_icon  = dialog-information

[urgency_normal]
    background    = "#1a1a28"
    foreground    = "#e0e0e0"
    frame_color   = "#bb9af7"
    highlight     = "#e29bd8"
    timeout       = 6
    default_icon  = dialog-information

[urgency_critical]
    background    = "#1a1a28"
    foreground    = "#f14c4c"
    frame_color   = "#f14c4c"
    highlight     = "#f14c4c"
    timeout       = 0
    default_icon  = dialog-error
