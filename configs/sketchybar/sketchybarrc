#!/bin/bash

ITEM_DIR="$CONFIG_DIR/items"
PLUGIN_DIR="$CONFIG_DIR/plugins"

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

# Bar

sketchybar --bar \
  position=top \
  height=36 \
  color=$TRANSPARENT \
  shadow=off \
  corner_radius=0 \
  border_width=0 \
  blur_radius=0 \
  y_offset=0 \
  margin=0 \
  padding_left=10 \
  padding_right=10

# Defaults

sketchybar --default \
  icon.font="DankMono Nerd Font Mono:Regular:16.0" \
  icon.color=$FG_MUTED \
  icon.padding_left=8 \
  icon.padding_right=4 \
  label.font="SF Pro:Medium:13.0" \
  label.color=$FG_PRIMARY \
  label.padding_left=0 \
  label.padding_right=8 \
  background.height=28 \
  background.corner_radius=8

# Events

sketchybar --add event aerospace_workspace_change

# Left

source "$ITEM_DIR/aerospace.sh"
source "$ITEM_DIR/front_app.sh"

# Right (added right-to-left)

source "$ITEM_DIR/clock.sh"

sketchybar --add item spacer_right right \
  --set spacer_right \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=3 \
    padding_right=3

source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/volume.sh"

sketchybar --add item spacer_left right \
  --set spacer_left \
    icon.drawing=off \
    label.drawing=off \
    background.drawing=off \
    padding_left=3 \
    padding_right=3

source "$ITEM_DIR/cpu.sh"
source "$ITEM_DIR/memory.sh"
source "$ITEM_DIR/disk.sh"

# Bracket groups

sketchybar --add bracket stats disk memory cpu \
  --set stats \
    background.color=$BG_SECONDARY \
    background.corner_radius=8 \
    background.height=28 \
    background.drawing=on

sketchybar --add bracket controls volume wifi battery \
  --set controls \
    background.color=$BG_SECONDARY \
    background.corner_radius=8 \
    background.height=28 \
    background.drawing=on

sketchybar --add bracket time clock \
  --set time \
    background.color=$BG_SECONDARY \
    background.corner_radius=8 \
    background.height=28 \
    background.drawing=on

sketchybar --hotload true
sketchybar --update
