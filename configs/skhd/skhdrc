# Focus window (vim-style)
alt - h : yabai -m window --focus west  || true
alt - j : yabai -m window --focus south || true
alt - k : yabai -m window --focus north || true
alt - l : yabai -m window --focus east  || true

# Move / swap window
shift + alt - h : yabai -m window --warp west  || true
shift + alt - j : yabai -m window --warp south || true
shift + alt - k : yabai -m window --warp north || true
shift + alt - l : yabai -m window --warp east  || true

# Resize window
ctrl + alt - h : yabai -m window --resize left:-50:0;  yabai -m window --resize right:-50:0
ctrl + alt - j : yabai -m window --resize bottom:0:50; yabai -m window --resize top:0:50
ctrl + alt - k : yabai -m window --resize top:0:-50;   yabai -m window --resize bottom:0:-50
ctrl + alt - l : yabai -m window --resize right:50:0;  yabai -m window --resize left:50:0

# Space switching
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9

# Display switching
alt - right  : yabai -m display --focus prev
alt - left : yabai -m display --focus next

# Move current workspace between monitors
shift + alt - right  : yabai -m space --display prev; yabai -m display --focus prev
shift + alt - left : yabai -m space --display next; yabai -m display --focus next

# Move window to space
shift + alt - 1 : yabai -m window --space 1 --focus
shift + alt - 2 : yabai -m window --space 2 --focus
shift + alt - 3 : yabai -m window --space 3 --focus
shift + alt - 4 : yabai -m window --space 4 --focus
shift + alt - 5 : yabai -m window --space 5 --focus
shift + alt - 6 : yabai -m window --space 6 --focus
shift + alt - 7 : yabai -m window --space 7 --focus
shift + alt - 8 : yabai -m window --space 8 --focus
shift + alt - 9 : yabai -m window --space 9 --focus

# Layout
alt - r : yabai -m space --rotate 90
alt - e : yabai -m window --toggle split
alt - f : yabai -m window --toggle float; yabai -m window --grid 4:4:1:1:2:2
alt - m : yabai -m window --toggle zoom-fullscreen

# Balance all windows equally
shift + alt - b : yabai -m space --balance

# Appsssss
alt - return : open -na Ghostty
alt - b      : open Helium
alt - v      : open Vesktop
alt - m      : open Music
