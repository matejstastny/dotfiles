// --------------------------------------------------------------------------------------------
// settings.json - my visual studio code settings
// --------------------------------------------------------------------------------------------
// Author: Matej Stastny
// Date: 2025-07-15 (YYYY-MM-DD)
// License: MIT
// Link: https://github.com/matejstastny/dotfiles
// --------------------------------------------------------------------------------------------
{
    "workbench.colorTheme": "Aura Dracula Spirit",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.editor.showTabs": "single",
    "workbench.editor.empty.hint": "hidden",
    "workbench.sideBar.location": "right",
    "workbench.startupEditor": "none",
    "workbench.tips.enabled": false,
    "editor.minimap.enabled": false,
    "breadcrumbs.enabled": false,
    // Sidebar & file explorer
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "explorer.sortOrder": "type",
    "material-icon-theme.hidesExplorerArrows": true,
    "workbench.tree.enableStickyScroll": false,
    "workbench.tree.renderIndentGuides": "none",
    "workbench.tree.indent": 16,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "explorer.decorations.badges": false,
    "git.decorations.enabled": false,
    "explorer.compactFolders": false,
    // Custom UI Style extension
    "window.newWindowDimensions": "maximized",
    "window.zoomLevel": 0.8,
    "window.menuBarVisibility": "toggle",
    "window.customTitleBarVisibility": "never",
    "window.titleBarStyle": "native",
    "custom-ui-style.electron": {
        "titleBarStyle": "hiddenInset",
        "trafficLightPosition": {
            "x": 16,
            "y": 12
        }
    },
    "custom-ui-style.stylesheet": {
        ".quick-input-widget": "top: 25vh !important",
        ".monaco-scrollable-element > .shadow.top": "display: none",
        ".sidebar .title-label": "padding: 0 !important",
        ".monaco-editor .scroll-decoration": "display: none",
        ".title.show-file-icons .label-container .monaco-icon-label.file-icon": "justify-content: center; padding: 0 !important",
        ".title .monaco-icon-label:after": "margin-rightw: 0",
        ".monaco-workbench .part.editor > .content .editor-group-container > .title > .label-container > .title-label": "padding-left: 80px",
        ".title .monaco-icon-label.file-icon": "margin: 0 60px"
    },
    "custom-ui-style.font.sansSerif": "JetBrainsMono Nerd Font",
    // Cursor
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.cursorBlinking": "phase",
    "editor.cursorStyle": "line",
    "editor.cursorWidth": 2,
    "workbench.colorCustomizations": {
        // Remote host
        "statusBarItem.remoteBackground": "#FFFFFF00",
        "statusBarItem.remoteForeground": "#9DA5B4",
        // Borders
        "statusBar.border": "#FFFFFF26",
        "sideBar.border": "#FFFFFF26",
        "panel.border": "#FFFFFF26"
    },
    // Typography
    "editor.fontFamily": "JetBrainsMono Nerd Font",
    "editor.fontSize": 13.5,
    "editor.fontLigatures": false,
    "editor.lineHeight": 1.7,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "comment",
                "settings": {
                    "fontStyle": "italic"
                }
            }
        ]
    },
    // Decorations & hints
    "editor.stickyScroll.enabled": false,
    "editor.colorDecorators": false,
    "editor.codeLens": false,
    "editor.lightbulb.enabled": "off",
    "editor.matchBrackets": "never",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    // Guides & highlights
    "editor.tabSize": 4,
    "editor.inlayHints.enabled": "off",
    "editor.detectIndentation": false,
    "editor.showFoldingControls": "mouseover",
    "editor.guides.indentation": false,
    "editor.renderWhitespace": "none",
    "editor.selectionHighlight": false,
    // Scrollbars
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "hidden",
    "editor.overviewRulerBorder": false,
    "editor.hideCursorInOverviewRuler": true,
    // Other
    "editor.snippetSuggestions": "top",
    "files.autoSave": "afterDelay",
    "update.mode": "none",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "workbench.settings.editor": "json",
    // Trust all files, I know what I'm doing VSCode
    "security.workspace.trust.untrustedFiles": "open",
    // Git
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.replaceTagsWhenPull": true,
    "git.suggestSmartCommit": false,
    "git.openRepositoryInParentFolders": "always",
    // ------------------------------------------------------------
    // EXTENSIONS CONFIG
    // ------------------------------------------------------------
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    // @ext ms-azuretools.vscode-docker
    "docker.extension.dockerEngineAvailabilityPrompt": false,
    "[dockerfile]": {
        "editor.semanticHighlighting.enabled": false
    },
    // @ext ms-vscode.cpptools-extension-pack
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.type": "sameLine",
    "C_Cpp.vcFormat.newLine.closeBraceSameLine.emptyType": true,
    "C_Cpp.formatting": "vcFormat",
    "C_Cpp.vcFormat.indent.accessSpecifiers": true,
    "C_Cpp.vcFormat.newLine.beforeElse": false,
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.block": "sameLine",
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.function": "sameLine",
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.lambda": "sameLine",
    "C_Cpp.vcFormat.newLine.beforeOpenBrace.namespace": "sameLine",
    "C_Cpp.vcFormat.newLine.closeBraceSameLine.emptyFunction": true,
    "C_Cpp.vcFormat.newLine.beforeCatch": false,
    "C_Cpp.doxygen.generatedStyle": "/**",
    // @ext geequlim.godot-tools
    "godotTools.editorPath.godot4": "/Applications/Godot.app/Contents/MacOS/Godot",
    // @ext jsynowiec.vscode-insertdatestring
    "insertDateString.format": "YYYY-MM-DD hh:mm:ss",
    "insertDateString.formatDate": "YYYY-MM-DD",
    "insertDateString.formatTime": "hh:mm:ss",
    "editor.scrollbar.verticalScrollbarSize": 0,
    // @ext pixl-garden.BongoCat
    "workbench.productIconTheme": "bongocat",
    "docker.extension.enableComposeLanguageServer": false,
    // Rest of unsorted autogened settings slop :3
    "github.copilot.nextEditSuggestions.enabled": true,
    "prettier.trailingComma": "none",
    "chat.viewSessions.enabled": false,
    "[shellscript]": {
        "editor.defaultFormatter": "mkhl.shfmt"
    },
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false
    },
    "customAppIcons.path": "~/Library/Application Support/Code/User/icons",
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "lldb.suppressUpdateNotifications": true,
    "security.promptForRemoteFileProtocolHandling": false,
    "chat.tools.urls.autoApprove": {
        "https://github.com": {
            "approveRequest": false,
            "approveResponse": true
        },
        "https://v2.tauri.app": {
            "approveResponse": true
        }
    },
    "json.schemaDownload.trustedDomains": {
        "https://developer.microsoft.com/json-schemas/": true,
        "https://github.com": true,
        "https://json-schema.org/": true,
        "https://json.schemastore.org/": true,
        "https://raw.githubusercontent.com/devcontainers/spec/": true,
        "https://raw.githubusercontent.com/microsoft/vscode/": true,
        "https://schemastore.azurewebsites.net/": true,
        "https://www.schemastore.org/": true
    }
}
